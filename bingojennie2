<!DOCTYPE html>
<html lang="lo">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>BINGO X JENNIE</title>
   <style>
       body { font-family: sans-serif; background: #f0f2f5; text-align: center; padding: 20px; }
       .container { max-width: 500px; margin: auto; background: white; padding: 20px; border-radius: 15px; }
       .grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 5px; margin-top: 15px; }
       .cell { aspect-ratio: 1; border: 1px solid #ccc; display: flex; align-items: center; justify-content: center; font-weight: bold; cursor: pointer; background: #fff; }
       .cell.selected { background: #ff4757; color: white; }
       .cell.free { background: #ffa502; color: black; }
       button.btn { background: #ff4757; color: white; padding: 12px; border: none; border-radius: 5px; width: 100%; margin-top: 10px; cursor: pointer; }
   </style>
</head>
<body>
   <div class="container">
       <h1>BINGO X JENNIE</h1>
       <div id="setup-area">
           <input type="text" id="player-name" placeholder="ໃສ່ຊື່..." style="padding:10px; width:80%;">
           <button class="btn" onclick="startGame()">ເຂົ້າຮ່ວມເກມ</button>
       </div>

       <div id="game-area" style="display:none;">
           <button class="btn" onclick="initAudio()">🔊 ເປີດສຽງ (ກົດກ່ອນຫຼິ້ນ)</button>
           <div id="status-display" style="font-weight:bold; margin-top:15px; color:red;">ລໍຖ້າເລີ່ມ...</div>
           <div id="host-controls" style="display:none;">
               <button class="btn" onclick="toggleAuto()">▶️ ເລີ່ມ/ຢຸດ ອໍໂຕ້</button>
               <button class="btn" onclick="resetGame()">🔄 ເລີ່ມເກມໃໝ່</button>
           </div>
           <div class="grid" id="bingo-board"></div>
           <p>ເລກທີ່ອອກແລ້ວ: <br><span id="called-numbers" style="word-break: break-all;"></span></p>
       </div>
   </div>

   <script type="module">
       import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
       import { getDatabase, ref, set, onValue, update } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";

       const db = getDatabase(initializeApp({ apiKey: "AIzaSyBOW0m7tdZl95srB6Mh2AcxNp9GQkTITrl", databaseURL: "https://bingoxjennie-default-rtdb.asia-southeast1.firebasedatabase.app", projectId: "bingoxjennie" }));
       const gameRef = ref(db, 'game_room');

       let pName = "", autoInterval = null;

       window.initAudio = () => { window.speechSynthesis.speak(new SpeechSynthesisUtterance("ເປີດສຽງແລ້ວ")); };

       window.startGame = () => {
           pName = document.getElementById('player-name').value;
           if(!pName) return alert("ໃສ່ຊື່ກ່ອນ!");
           document.getElementById('setup-area').style.display = 'none';
           document.getElementById('game-area').style.display = 'block';
           generateBoard();
       };

       function generateBoard() {
           let nums = Array.from({length: 75}, (_, i) => i + 1).sort(() => Math.random() - 0.5).slice(0, 25);
           nums[12] = "FREE";
           const board = document.getElementById('bingo-board');
           board.innerHTML = "";
           nums.forEach((n) => {
               const div = document.createElement('div');
               div.className = "cell" + (n === "FREE" ? " free selected" : "");
               div.innerText = n === "FREE" ? "★" : n;
               div.onclick = () => {
                   const called = document.getElementById('called-numbers').innerText.split(', ');
                   if (n === "FREE" || called.includes(n.toString())) {
                       div.classList.add('selected');
                       if (checkWin()) update(gameRef, { winner: pName });
                   }
               };
               board.appendChild(div);
           });
       }

       function checkWin() {
           let cells = Array.from(document.querySelectorAll('.cell'));
           let m = []; for(let i=0; i<5; i++) m.push(cells.slice(i*5, i*5+5).map(e => e.classList.contains('selected')));
           for(let i=0; i<5; i++) { if(m[i].every(v => v) || m.map(r => r[i]).every(v => v)) return true; }
           return [0,1,2,3,4].every(i => m[i][i]) || [0,1,2,3,4].every(i => m[i][4-i]);
       }

       window.toggleAuto = () => {
           if(autoInterval) { clearInterval(autoInterval); autoInterval = null; }
           else autoInterval = setInterval(() => {
               onValue(gameRef, (snap) => {
                   let d = snap.val();
                   if(d && !d.winner) {
                       let called = d.called || [];
                       let available = Array.from({length: 75}, (_, i) => i + 1).filter(n => !called.includes(n));
                       if(available.length > 0) {
                           let n = available[Math.floor(Math.random() * available.length)];
                           update(gameRef, { called: [...called, n], latest: n });
                       }
                   }
               }, {onlyOnce: true});
           }, 5000);
       };

       // ແກ້ໄຂ: ໃຊ້ Date.now() ເພື່ອສ້າງຄ່າ Reset ໃໝ່ສະເໝີ 
       // ປ້ອງກັນບັນຫາ Firebase Cache ບໍ່ຍອມລ້າງ
       window.resetGame = () => {
           set(gameRef, { 
               called: [0], 
               winner: null, 
               latest: null,
               resetTrigger: Date.now() 
           });
       };

       onValue(gameRef, (snap) => {
           const data = snap.val();
           if(!data) return;

           // ຖ້າຫາກມີການ resetTrigger ປ່ຽນແປງ ໃຫ້ສັ່ງລ້າງໜ້າຈໍ ແລະ ສຸ່ມກະດານໃໝ່ທັນທີ
           if(data.resetTrigger) {
               document.getElementById('status-display').innerText = "ເລີ່ມເກມໃໝ່!";
               document.getElementById('called-numbers').innerText = "";
               if(document.getElementById('game-area').style.display === 'block') {
                   generateBoard();
               }
               // ຫຼັງຈາກ generate ໃໝ່ແລ້ວ ໃຫ້ລ້າງ trigger ອອກ
               update(gameRef, { resetTrigger: null });
           }

           if(data.winner) {
               document.getElementById('status-display').innerHTML = `🎉 ຜູ້ຊະນະຄື: ${data.winner}`;
               clearInterval(autoInterval);
           } else if(data.latest) {
               document.getElementById('called-numbers').innerText = (data.called || []).filter(x => x !== 0).join(', ');
               document.getElementById('status-display').innerText = "ເລກຫຼ້າສຸດ: " + data.latest;
               let msg = new SpeechSynthesisUtterance(data.latest.toString());
               msg.lang = 'th-TH';
               window.speechSynthesis.speak(msg);
           }
       });

       if(new URLSearchParams(window.location.search).get('host')) document.getElementById('host-controls').style.display = 'block';
   </script>
</body>
</html>
